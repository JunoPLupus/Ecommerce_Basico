{
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.0"
  },
  "devDependencies": {
    "sass": "^1.99.0",
    "copyfiles": "^2.4.1"
  },
  "scripts": {
    "compile-sass": "sass src/main/scss/main.scss src/main/resources/static/css/main.css",
    "watch-sass": "sass --watch src/main/scss/main.scss src/main/resources/static/css/main.css",
    "postinstall": "copyfiles -f node_modules/bootstrap/dist/js/bootstrap.bundle.min.js src/main/resources/static/js && copyfiles -f node_modules/bootstrap-icons/font/fonts/* src/main/resources/static/css/fonts"
  }
}
